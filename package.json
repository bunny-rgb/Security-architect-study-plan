{
  "name": "security-architect-training",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:frontend": "next dev",
    "dev:api": "vite",
    "dev": "wrangler pages dev out --d1=webapp-production --local --ip 0.0.0.0 --port 3000 --live-reload",
    "build:api": "vite build",
    "build:frontend": "next build",
    "build": "npm run build:api && npm run build:frontend && npm run combine",
    "combine": "mkdir -p dist && cp -r out/* dist/ && cp public/_routes.json dist/ 2>/dev/null || true",
    "preview": "wrangler pages dev dist --d1=webapp-production --local",
    "deploy": "npm run build && wrangler pages deploy dist --project-name webapp",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "db:create": "wrangler d1 create webapp-production",
    "db:migrate:local": "wrangler d1 migrations apply webapp-production --local",
    "db:migrate:prod": "wrangler d1 migrations apply webapp-production",
    "db:seed:local": "wrangler d1 execute webapp-production --local --file=./seed.sql",
    "db:reset": "rm -rf .wrangler/state/v3/d1 && npm run db:migrate:local && npm run db:seed:local",
    "clean-port": "fuser -k 3000/tcp 2>/dev/null || true",
    "start:pm2": "pm2 start ecosystem.config.cjs",
    "stop:pm2": "pm2 delete webapp 2>/dev/null || true",
    "logs:pm2": "pm2 logs webapp --nostream"
  },
  "dependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "hono": "^4.12.3",
    "next": "^14.2.35",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250105.0",
    "@hono/vite-build": "^1.2.0",
    "@hono/vite-cloudflare-pages": "^0.4.2",
    "@hono/vite-dev-server": "^0.18.2",
    "@tailwindcss/postcss": "^4.2.1",
    "@types/node": "^25.3.3",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.3.5",
    "wrangler": "^4.4.0"
  }
}
